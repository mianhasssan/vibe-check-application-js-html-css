# ============================================
# VIBE CHECK MACHINE - .gitignore
# ============================================

# IDE & Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node.js (if using build tools in future)
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# OS Files
.env.local
.env.*.local

# Build/Distribution
dist/
build/

# Logs
*.log
logs/

# Dependencies (if added later)
.dependencies

# Local development
.local
.cache/
